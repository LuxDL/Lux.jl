        -     ax = CairoMakie.Axis(fig[1, 1]; xlabel="Iteration", ylabel="Loss")
        - 
        -     lines!(ax, losses; linewidth=4, alpha=0.75)
        -     scatter!(ax, 1:length(losses), losses; markershape=:circle,
        -         markersize=12, markeralpha=0.25, strokewidth=2)
